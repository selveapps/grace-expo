{
  "expo": {
    "name": "Grace",
    "slug": "grace",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "platforms": ["ios", "android", "web"],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "grace",
    "splash": {
      "backgroundColor": "#241a12",
