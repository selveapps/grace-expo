{
  "expo": {
    "name": "Grace",
    "slug": "grace",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "grace",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#3a2c22",
      "resizeMode": "contain",
      "image": "./assets/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.selveapps.grace",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.selveapps.grace"
    },
    "extra": {
      "eas": {
        "projectId": "0683c24c-9b77-4f1e-a9ec-54d6105dcb0c"
      }
    },
    "owner": "selveapps"
  }
}
