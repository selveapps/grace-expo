# Local development — copy to .env (never commit .env)
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# From Railway Postgres plugin → Connect tab
DATABASE_URL=postgresql://user:pass@host:port/railway

# openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Comma-separated origins, or * for beta
CORS_ORIGINS=*
