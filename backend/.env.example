# Local development — copy to .env (never commit .env)
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Local E2E (docker compose in backend/)
DATABASE_URL=postgresql://grace:grace@localhost:5433/grace

# Railway Postgres plugin → Connect tab (staging — provisioned 2026-07-13)
# DATABASE_URL=postgresql://...@shuttle.proxy.rlwy.net:.../railway

# Staging API (for verify:staging)
# STAGING_API_URL=https://grace-api-production.up.railway.app

# openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Comma-separated origins, or * for beta
CORS_ORIGINS=*

# Beta redeem code for POST /beta/redeem (Expo Go beta — no IAP)
BETA_REDEEM_CODE=grace-beta
